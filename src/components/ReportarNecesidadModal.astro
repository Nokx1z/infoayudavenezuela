<dialog id="reportarNecesidadDialog" class="modal-dialog" aria-labelledby="reportarDialogTitle">
  <div class="modal-content">
    <div class="modal-header">
      <h2 id="reportarDialogTitle">🆘 Reportar Necesidad Urgente</h2>
      <button id="closeNecesidadDialogBtn" class="close-btn" aria-label="Cerrar modal">&times;</button>
    </div>
    <form id="reportarNecesidadForm" class="modal-form">
      <p class="form-help">Reporta un lugar, refugio o persona que necesite ayuda urgente. Será publicado tras ser verificado.</p>

      <div class="alert-box" style="margin-bottom: 1rem; padding: 0.6rem; border-radius: 6px; font-size: 0.8rem;">
        <svg width="20" height="20" fill="none" stroke="currentColor" viewBox="0 0 24 24" style="flex-shrink: 0;"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
        <span>Para reportar necesidades en <strong>otros países</strong>, selecciona <strong>"Internacional"</strong> en la lista de Estados.</span>
      </div>

      <div class="form-group">
        <label for="necFormEstado">Estado *</label>
        <select id="necFormEstado" required>
          <option value="">Selecciona un estado</option>
          <option value="Internacional">Internacional</option>
          <option value="Distrito Capital">Distrito Capital</option>
          <option value="Miranda">Miranda</option>
          <option value="La Guaira">La Guaira</option>
          <option value="Aragua">Aragua</option>
          <option value="Carabobo">Carabobo</option>
          <option value="Lara">Lara</option>
          <option value="Sucre">Sucre</option>
          <option value="Nueva Esparta">Nueva Esparta</option>
          <option value="Anzoátegui">Anzoátegui</option>
          <option value="Bolívar">Bolívar</option>
          <option value="Barinas">Barinas</option>
          <option value="Monagas">Monagas</option>
          <option value="Yaracuy">Yaracuy</option>
          <option value="Zulia">Zulia</option>
          <option value="Mérida">Mérida</option>
          <option value="Táchira">Táchira</option>
          <option value="Trujillo">Trujillo</option>
          <option value="Falcón">Falcón</option>
          <option value="Cojedes">Cojedes</option>
          <option value="Portuguesa">Portuguesa</option>
          <option value="Guárico">Guárico</option>
          <option value="Apure">Apure</option>
          <option value="Delta Amacuro">Delta Amacuro</option>
          <option value="Amazonas">Amazonas</option>
        </select>
      </div>

      <div class="form-row">
        <div class="form-group" id="necFormPaisGroup" style="display: none;">
        <label for="necFormPais">País *</label>
        <input type="text" id="necFormPais" list="paises-list" placeholder="Selecciona o escribe un país" maxlength="60" autocomplete="off" />
        <datalist id="paises-list">
          <option value="Colombia"></option>
          <option value="Perú"></option>
          <option value="Chile"></option>
          <option value="Argentina"></option>
          <option value="Ecuador"></option>
          <option value="Brasil"></option>
          <option value="España"></option>
          <option value="Estados Unidos"></option>
          <option value="México"></option>
          <option value="Panamá"></option>
          <option value="Uruguay"></option>
          <option value="Costa Rica"></option>
          <option value="República Dominicana"></option>
        </datalist>
      </div>

      <div class="form-group">
        <label for="necFormCiudad">Ciudad *</label>
        <input type="text" id="necFormCiudad" placeholder="Ej. Barquisimeto, Macuto" required />
      </div>
        <div class="form-group">
          <label for="necFormLugar">Lugar / Nombre *</label>
          <input type="text" id="necFormLugar" placeholder="Ej. Refugio La Paz, Centro Comunitario" required />
        </div>
      </div>

      <div class="form-group">
        <label for="necFormDireccion">Dirección</label>
        <textarea id="necFormDireccion" rows="2" placeholder="Dirección del lugar que necesita ayuda..."></textarea>
      </div>

      <div class="form-group">
        <label for="necFormNecesitan">¿Qué necesitan URGENTE? *</label>
        <textarea id="necFormNecesitan" rows="3" placeholder="Describe lo que más necesitan: medicinas, agua, alimentos, ropa, carpas, etc..." required></textarea>
      </div>

      <div class="form-group">
        <label for="necFormContacto">Contacto</label>
        <input type="text" id="necFormContacto" placeholder="Teléfono, Instagram, email..." />
      </div>

      <div class="form-actions">
        <button type="button" id="cancelNecFormBtn" class="btn btn-secondary">Cancelar</button>
        <button type="submit" id="submitNecFormBtn" class="btn btn-primary" style="background: var(--red);">Enviar Reporte</button>
      </div>
    </form>

    <div id="necFormSuccessMessage" class="form-success-msg" style="display: none;">
      <div class="success-icon">✓</div>
      <h3>¡Reporte Enviado!</h3>
      <p>Gracias por reportar esta necesidad urgente. Los datos han sido registrados de forma segura y se publicarán tan pronto sean verificados por un moderador.</p>
      <button id="necSuccessCloseBtn" class="btn btn-primary">Entendido</button>
    </div>
  </div>
</dialog>
