---
import Layout from "../layouts/Layout.astro";
import { SITE_URL } from "../lib/site.js";

interface RecursoNinez {
  titulo: string;
  descripcion: string;
  fuente: string;
  detalle?: string;
  url: string;
  tipo: "externo" | "interno" | "proximamente";
}

const recursos: RecursoNinez[] = [
  {
    titulo: "Protección de la niñez en emergencias — normas y estándares",
    descripcion: "Principios y estándares mínimos reconocidos internacionalmente para proteger a niños, niñas y adolescentes durante una respuesta humanitaria.",
    fuente: "Alliance for Child Protection in Humanitarian Action",
    detalle: "Normas Mínimas para la Protección de la Infancia en la Acción Humanitaria",
    url: "https://spherestandards.org",
    tipo: "externo",
  },
  {
    titulo: "Niños separados o no acompañados",
    descripcion: "Qué hacer y a quién acudir si se identifica a un niño solo o separado de su familia en un refugio.",
    fuente: "Cecodap",
    url: "https://cecodap.org",
    tipo: "externo",
  },
  {
    titulo: "Primeros auxilios psicológicos para niños y niñas",
    descripcion: "Guía práctica de apoyo psicosocial elaborada tras un terremoto, con foco específico en la niñez.",
    fuente: "UNICEF Chile",
    detalle: "Para Reconstruir la Vida de los Niños y Niñas",
    url: "https://www.unicef.org/chile",
    tipo: "externo",
  },
  {
    titulo: "Espacios seguros y juego en emergencias",
    descripcion: "Guía operativa para montar espacios amigables para la niñez: actividades, materiales y cómo organizarlos con recursos limitados.",
    fuente: "World Vision International / Centro de Referencia IFRC para el Apoyo Psicosocial",
    detalle: "Guía operativa para Espacios Amigables para la Niñez en Entornos Humanitarios",
    url: "https://www.unicef.org/honduras",
    tipo: "externo",
  },
  {
    titulo: "Apoyo emocional para quien cuida",
    descripcion: "El bienestar del voluntario también importa: recursos breves de autocuidado para quien acompaña a niños en contextos de crisis.",
    fuente: "Recurso del sitio",
    url: "/salud-mental",
    tipo: "proximamente",
  },
];

interface GrupoDonacion {
  grupo: string;
  rango: string;
  items: string[];
}

const gruposDonacion: GrupoDonacion[] = [
  {
    grupo: "Para los más pequeños",
    rango: "0 a 5 años",
    items: [
      "Pañales de todas las tallas y toallitas húmedas.",
      "Fórmula infantil y biberones.",
      "Ropa de bebé, mantas y gorros según el clima.",
      "Jabón y champú neutros, para piel sensible.",
      "Juguetes sensoriales o de tela nuevos (evitar peluches usados).",
    ],
  },
  {
    grupo: "Para niños más grandes",
    rango: "6 a 12 años",
    items: [
      "Ropa y calzado por talla y temporada.",
      "Kits escolares: cuadernos, lápices, sacapuntas, mochilas.",
      "Kits de higiene personal (jabón, cepillo, pasta dental, champú).",
      "Materiales de juego: pelotas, cuerdas, plastilina, creyones.",
      "Linternas o lámparas de baterías para las noches en el refugio.",
    ],
  },
];

const pageTitle = "Ayuda para los más pequeños";
const pageDescription = "Recursos verificados para cuidar y proteger a niños y niñas durante la emergencia.";

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  itemListElement: recursos
    .filter((r) => r.tipo === "externo")
    .map((r, i) => ({
      "@type": "ListItem",
      position: i + 1,
      name: r.titulo,
      url: r.url,
    })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`${SITE_URL}/proteccion-infantil`}
  showHero={false}
>
  <header class="relative -mt-4 md:-mt-6 mb-6 w-screen ml-[calc(-50vw+50%)] overflow-hidden bg-gradient-to-br from-blue via-blue-dark to-blue text-white">
    <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,rgba(255,255,255,0.04)_20px,rgba(255,255,255,0.04)_40px)]" aria-hidden="true"></div>
    <div class="relative max-w-[640px] mx-auto text-center px-5 py-10 sm:py-12">
      <span class="inline-flex items-center gap-1.5 bg-white/15 border border-white/25 text-white text-[0.7rem] font-extrabold uppercase tracking-[0.06em] px-3 py-1 rounded-full mb-4">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Protección infantil
      </span>
      <h1 class="text-2xl sm:text-[1.9rem] font-extrabold tracking-tight leading-tight text-balance mb-2">
        Ayuda para los <span class="text-yellow">más pequeños</span>
      </h1>
      <p class="text-sm sm:text-[0.9rem] text-white/85 max-w-[480px] mx-auto leading-relaxed text-balance">
        Recursos verificados para cuidar y proteger a niños y niñas durante la emergencia.
      </p>
    </div>
  </header>

  <section aria-label="Mensaje de bienvenida" class="mb-8 bg-white rounded-card border border-border p-6 sm:p-7 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
    <p class="text-[1.02rem] sm:text-[1.08rem] font-semibold text-text leading-relaxed text-balance">
      Después de estos días tan difíciles, muchos niños y niñas necesitan algo muy sencillo: sentirse seguros otra vez.
    </p>
    <p class="mt-3 text-[0.92rem] text-[#4B5563] leading-relaxed text-pretty">
      No hace falta ser experto para ayudarles. A veces basta con sentarse a su lado, jugar un rato, escucharlos sin apuro, y saber a quién llamar si algo no anda bien.
    </p>
    <p class="mt-3 text-[0.92rem] text-[#4B5563] leading-relaxed text-pretty">
      Aquí reunimos, en un solo lugar, recursos pensados por quienes más saben de esto, para que puedas cuidar a los más pequeños con cariño… y con la tranquilidad de estar haciendo lo correcto.
    </p>
  </section>

  <section aria-labelledby="recursos-titulo" class="mb-10">
    <div class="mb-4">
      <h2 id="recursos-titulo" class="flex items-center gap-2 text-[1.05rem] font-bold text-text tracking-tight text-balance">
        <svg class="text-blue shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
        Recursos de protección y apoyo
      </h2>
      <p class="mt-1.5 text-[0.86rem] text-muted leading-relaxed text-pretty max-w-[640px]">
        Materiales elaborados por organismos con experiencia en protección infantil. Cada enlace lleva a una fuente confiable con orientación práctica.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
      {recursos.map((r) => (
        r.tipo === "proximamente" ? (
          <article class="relative flex flex-col bg-white rounded-card border border-border p-5 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
            <div class="flex items-start justify-between gap-3 mb-2">
              <h3 class="text-[0.98rem] font-bold text-text leading-snug tracking-tight text-balance">{r.titulo}</h3>
              <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-pill text-[0.66rem] font-bold uppercase tracking-wide bg-bg text-muted border border-border">Próximamente</span>
            </div>
            <p class="text-[0.86rem] text-[#4B5563] leading-relaxed text-pretty">{r.descripcion}</p>
            <span class="mt-auto pt-3 text-[0.74rem] font-semibold text-muted">{r.fuente}</span>
          </article>
        ) : (
          <a
            href={r.url}
            target={r.tipo === "externo" ? "_blank" : undefined}
            rel={r.tipo === "externo" ? "noopener noreferrer" : undefined}
            class="group relative flex flex-col bg-white rounded-card border border-border p-5 no-underline shadow-[0_1px_2px_rgba(16,24,40,0.04)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-blue hover:shadow-[0_8px_24px_rgba(0,36,125,0.1)]"
          >
            <div class="flex items-start justify-between gap-3 mb-2">
              <h3 class="text-[0.98rem] font-bold text-text leading-snug tracking-tight text-balance">{r.titulo}</h3>
              <svg class="shrink-0 mt-0.5 text-muted transition-colors duration-200 group-hover:text-blue" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M7 17 17 7M8 7h9v9"/></svg>
            </div>
            <p class="text-[0.86rem] text-[#4B5563] leading-relaxed text-pretty">{r.descripcion}</p>
            {r.detalle && (
              <p class="mt-2 text-[0.78rem] text-muted italic leading-snug text-pretty">«{r.detalle}»</p>
            )}
            <span class="mt-auto pt-3 text-[0.74rem] text-muted">
              Fuente: <span class="font-semibold text-text">{r.fuente}</span>
            </span>
            {r.tipo === "externo" && <span class="sr-only">(se abre en una nueva pestaña)</span>}
          </a>
        )
      ))}
    </div>
  </section>

  <section aria-labelledby="donar-titulo" class="mb-10">
    <div class="mb-4">
      <h2 id="donar-titulo" class="flex items-center gap-2 text-[1.05rem] font-bold text-text tracking-tight text-balance">
        <svg class="text-blue shrink-0" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M20.42 4.58a5.4 5.4 0 0 0-7.65 0l-.77.78-.77-.78a5.4 5.4 0 0 0-7.65 0C1.46 6.7 1.33 10.28 4 13l8 8 8-8c2.67-2.72 2.54-6.3.42-8.42z"/></svg>
        Qué se puede donar para niños y niñas
      </h2>
    </div>

    <div class="mb-4 flex items-start gap-3 bg-white rounded-card border border-border p-4 sm:p-5 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
      <svg class="shrink-0 mt-0.5 text-blue" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4M12 8h.01"/></svg>
      <p class="text-[0.86rem] text-[#4B5563] leading-relaxed text-pretty">
        Prioriza la <strong class="text-text">donación en dinero por canales oficiales</strong>: permite comprar lo necesario localmente y responder más rápido. Los artículos físicos deben <strong class="text-text">coordinarse siempre con un punto de acopio</strong> antes de enviarse. Esta lista es una referencia de qué es más útil, no una invitación a enviar cosas sin coordinar.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {gruposDonacion.map((g) => (
        <article class="flex flex-col bg-white rounded-card border border-border p-5 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
          <div class="flex items-center justify-between gap-3 mb-3 pb-3 border-b border-border">
            <h3 class="text-[0.95rem] font-bold text-text tracking-tight">{g.grupo}</h3>
            <span class="shrink-0 text-[0.74rem] font-semibold text-muted tabular-nums">{g.rango}</span>
          </div>
          <ul class="flex flex-col gap-2.5">
            {g.items.map((item) => (
              <li class="flex items-start gap-2 text-[0.86rem] text-[#4B5563] leading-snug text-pretty">
                <svg class="shrink-0 mt-0.5 text-muted" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M20 6 9 17l-5-5"/></svg>
                <span>{item}</span>
              </li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="mt-4">
      <a href="/donaciones" class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-5 py-3 min-h-11 rounded-lg font-semibold text-white bg-blue no-underline transition-colors duration-150 hover:bg-blue-dark">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M3 9h18M3 9l2-4h14l2 4M3 9v10a1 1 0 0 0 1 1h16a1 1 0 0 0 1-1V9M9 13h6"/></svg>
        Ver puntos de acopio y canales oficiales
      </a>
    </div>
  </section>

  <section aria-label="Descargo de responsabilidad" class="mb-8 bg-[#FEF2F2] rounded-card border border-border border-l-[5px] border-l-red p-5 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
    <h2 class="flex items-center gap-2 text-[0.95rem] font-bold text-red tracking-tight">
      <svg class="shrink-0" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>
      Descargo de responsabilidad
    </h2>
    <p class="text-[#991B1B] text-[0.9rem] leading-relaxed mt-2 text-pretty">
      Los recursos enlazados aquí son elaborados por organismos especializados en protección infantil y apoyo psicosocial. Este sitio <strong>no sustituye la atención de un profesional</strong>; ante una situación de riesgo inmediato para un niño o niña, contacta a los canales de emergencia disponibles en el refugio o comunidad.
    </p>
  </section>

  <div class="text-center">
    <a href="/" class="inline-flex items-center gap-1.5 text-sm font-medium text-muted no-underline px-4 py-2 rounded-lg transition-colors duration-150 hover:bg-[#F1F5F9] hover:text-text">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
      Volver al inicio
    </a>
  </div>

  <script type="application/ld+json" set:html={JSON.stringify(itemListLd)} is:inline />
</Layout>
