---
import Layout from "../layouts/Layout.astro";
import { SITE_URL } from "../lib/site.js";

interface RecursoNinez {
  titulo: string;
  descripcion: string;
  fuente: string;
  detalle?: string;
  url: string;
  tipo: "externo" | "interno" | "proximamente";
}

const recursos: RecursoNinez[] = [
  {
    titulo: "Cómo acompañar a la niñez tras un desastre",
    descripcion: "Guía para padres, madres, tutores y educadores: cómo hablar con la niñez, reconocer sus reacciones y darles contención en los primeros días después de una emergencia.",
    fuente: "UNICEF",
    detalle: "Guía para padres, madres, tutores y educadores",
    url: "https://www.unicef.org/chile/informes/gu%C3%ADas-para-padres-madres-tutores-y-educadores",
    tipo: "externo",
  },
  {
    titulo: "Protección de la niñez en emergencias — normas y estándares",
    descripcion: "Principios y estándares mínimos reconocidos internacionalmente para proteger a niños, niñas y adolescentes durante una respuesta humanitaria.",
    fuente: "Alliance for Child Protection in Humanitarian Action",
    detalle: "Normas Mínimas para la Protección de la Infancia en la Acción Humanitaria",
    url: "https://handbook.spherestandards.org/es/cpms/#ch001",
    tipo: "externo",
  },
  {
    titulo: "Niñez separada o no acompañada",
    descripcion: "Qué hacer y a quién acudir si hay niñas o niños solos o separados de su familia en un refugio.",
    fuente: "Cecodap",
    url: "https://cecodap.org/guia-de-actuacion-para-la-proteccion-de-ninos-ninas-y-adolescentes-no-acompanados-en-contextos-de-emergencia/",
    tipo: "externo",
  },
  {
    titulo: "Primeros auxilios psicológicos para la niñez",
    descripcion: "Guía práctica de apoyo psicosocial elaborada tras un terremoto, con foco específico en la niñez.",
    fuente: "UNICEF Chile",
    detalle: "Para Reconstruir la Vida de los Niños y Niñas",
    url: "https://www.unicef.org/chile/informes/gu%C3%ADa-para-apoyar-intervenciones-psicosociales-en-emergencias-y-desastres",
    tipo: "externo",
  },
  {
    titulo: "Espacios seguros y juego en emergencias",
    descripcion: "Guía operativa para montar espacios amigables para la niñez: actividades, materiales y cómo organizarlos con recursos limitados.",
    fuente: "World Vision International / Centro de Referencia IFRC para el Apoyo Psicosocial",
    detalle: "Guía operativa para Espacios Amigables para la Niñez en Entornos Humanitarios",
    url: "https://www.unicef.org/honduras/documents/gu%C3%ADa-operativa-para-espacios-amigables-para-la-ni%C3%B1ez-en-entornos-humanitarios",
    tipo: "externo",
  },
  {
    titulo: "Acompañamiento emocional en crisis o catástrofes",
    descripcion: "Pautas breves y accionables para contener emocionalmente a la niñez y la adolescencia tras una crisis o un desastre natural: validar sus emociones, limitar la exposición a noticias y transmitir calma.",
    fuente: "Save the Children España",
    url: "https://www.savethechildren.es/apoyo-emocional-infancia-en-catastrofes",
    tipo: "externo",
  },
  {
    titulo: "Apoyo emocional para quien cuida",
    descripcion: "El bienestar de quien cuida también importa: recursos breves de autocuidado para quien acompaña a la niñez en contextos de crisis.",
    fuente: "Recurso del sitio",
    url: "/salud-mental",
    tipo: "proximamente",
  },
];

interface GrupoDonacion {
  grupo: string;
  rango: string;
  items: string[];
}

const gruposDonacion: GrupoDonacion[] = [
  {
    grupo: "Primera infancia",
    rango: "0 a 5 años",
    items: [
      "Pañales de todas las tallas y toallitas húmedas.",
      "Fórmula infantil y biberones.",
      "Ropa de bebé, mantas y gorros según el clima.",
      "Jabón y champú neutros, para piel sensible.",
      "Juguetes sensoriales o de tela nuevos (evitar peluches usados).",
    ],
  },
  {
    grupo: "Niñez en edad escolar",
    rango: "6 a 12 años",
    items: [
      "Ropa y calzado por talla y temporada.",
      "Kits escolares: cuadernos, lápices, sacapuntas, mochilas.",
      "Kits de higiene personal (jabón, cepillo, pasta dental, champú).",
      "Materiales de juego: pelotas, cuerdas, plastilina, creyones.",
      "Linternas o lámparas de baterías para las noches en el refugio.",
    ],
  },
];

const multimedia: RecursoNinez[] = [
  {
    titulo: "Cuidándonos unos a otros",
    descripcion: "Videos, juegos y actividades de Plaza Sésamo para acompañar a la niñez y las familias en momentos de estrés: manejo de emociones, rutinas y contención.",
    fuente: "Sesame Workshop / Plaza Sésamo",
    url: "https://www.plazasesamo.com/cuidandonos",
    tipo: "externo",
  },
  {
    titulo: "Recursos en español para familias",
    descripcion: "Centro con videos, juegos y guías sobre sentimientos, emergencias y duelo para acompañar a la niñez en momentos difíciles.",
    fuente: "Sesame Workshop",
    url: "https://sesameworkshop.org/recursos-espanol/",
    tipo: "externo",
  },
  {
    titulo: "Curso de Crianza Positiva",
    descripcion: "Curso gratuito en videos con especialistas: manejo de emociones, límites con amor, importancia del juego y autocuidado de quien cuida.",
    fuente: "UNICEF México",
    url: "https://www.unicef.org/mexico/buentrato/curso-crianza-positiva",
    tipo: "externo",
  },
  {
    titulo: "Khan Academy en Español",
    descripcion: "Plataforma gratuita de aprendizaje en español para mantener a la niñez y la adolescencia estudiando durante el desplazamiento. Se usa en el navegador, sin instalar nada.",
    fuente: "Khan Academy",
    url: "https://es.khanacademy.org",
    tipo: "externo",
  },
];

interface Imprimible {
  titulo: string;
  descripcion: string;
  fuente: string;
  url: string;
  tipo: "descarga" | "externo";
  meta?: string;
}

const imprimibles: Imprimible[] = [
  {
    titulo: "Libro para colorear «Mundo Animal»",
    descripcion: "Láminas de animales para colorear, con el nombre en español e inglés. No necesita más que una impresora y creyones.",
    fuente: "Aportado por el equipo",
    url: "/ninez/imprimibles/libro-colorear-mundo-animal.pdf",
    tipo: "descarga",
    meta: "PDF · 4 MB",
  },
  {
    titulo: "Tarjetas de emociones",
    descripcion: "Ocho tarjetas ilustradas (feliz, triste, enojado, miedo, sorpresa, asco, amor, calma) para que la niñez señale cómo se siente cuando le cuesta decirlo con palabras.",
    fuente: "Aportado por el equipo",
    url: "/ninez/img/tarjetas-emociones.jpeg",
    tipo: "descarga",
    meta: "Imagen · 208 KB",
  },
  {
    titulo: "Cuaderno de actividades lúdicas",
    descripcion: "Actividades para armar en familia un plan de emergencia, pensadas para que la niñez las realice en casa o en espacios temporales.",
    fuente: "Save the Children Perú",
    url: "https://resourcecentre.savethechildren.net/es/document/children-activity-notebook-everyone-at-home-works-the-family-emergency-plan",
    tipo: "externo",
  },
  {
    titulo: "Cuadernillo de competencias socioemocionales (7 a 15 años)",
    descripcion: "Actividades para colorear y dibujar orientadas a identificar y expresar emociones (máscaras de emociones, mapeo corporal, autorretrato).",
    fuente: "Save the Children / UNICEF Honduras",
    url: "https://www.unicef.org/honduras/media/4431/file/SAVE%20THE%20CHILDREN%20CUADERNILLO%207%20A%2015.pdf.pdf",
    tipo: "externo",
    meta: "PDF",
  },
];

interface Cuento {
  titulo: string;
  descripcion: string;
  fuente: string;
  url: string;
  tipo: "descarga" | "externo";
  badge: string;
  meta?: string;
}

const cuentos: Cuento[] = [
  {
    titulo: "¿Qué se movió en Venezuela?",
    descripcion: "Cuento ilustrado en verso para explicarle a la niñez qué es un temblor y calmar el miedo después del sismo. De distribución gratuita.",
    fuente: "Andrea Torres Blanchard",
    url: "/ninez/cuentos/que-se-movio-en-venezuela.pdf",
    tipo: "descarga",
    badge: "Para leer aquí",
    meta: "PDF · 2.8 MB",
  },
  {
    titulo: "Biblioteca Virtual Infantil",
    descripcion: "Cientos de cuentos, fábulas y poesía de dominio público para leer libremente. Páginas de texto muy livianas.",
    fuente: "Bibliotecas Rurales Argentinas",
    url: "https://www.bibliotecasrurales.org.ar/biblioteca-virtual-infantil.php",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos infantiles",
    descripcion: "Portal de literatura infantil con cientos de cuentos clásicos y contemporáneos en español, a texto completo.",
    fuente: "Biblioteca Virtual Miguel de Cervantes",
    url: "https://www.cervantesvirtual.com/portales/biblioteca_literatura_infantil_juvenil/cuentos_infantiles/",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos que cuidan",
    descripcion: "Colección de cuentos ilustrados sobre derechos, inclusión y protección de la primera infancia, cada uno con guía de actividades.",
    fuente: "UNICEF",
    url: "https://www.unicef.org/chile/documents/serie-cuentos-que-cuidan",
    tipo: "externo",
    badge: "Enlace externo",
    meta: "PDF · pesado",
  },
  {
    titulo: "Cuentos para dormir",
    descripcion: "Cientos de cuentos cortos organizados por valores, pensados para leer antes de dormir. Incluye audiocuentos.",
    fuente: "Cuentopia Educativa",
    url: "https://cuentosparadormir.com/",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos infantiles cortos",
    descripcion: "Cuentos cortos ilustrados para leer y aprender valores, con actividades relacionadas.",
    fuente: "Árbol ABC",
    url: "https://arbolabc.com/cuentos-infantiles-cortos",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos para la niñez",
    descripcion: "Amplia colección de cuentos ilustrados en español para leer en línea.",
    fuente: "Ririro",
    url: "https://ririro.com/es/",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos para calmar y dormir",
    descripcion: "Cuentos diseñados para calmar antes de dormir, con enfoque en autoestima y emociones. Se pueden leer en voz alta o escuchar en audio.",
    fuente: "Émora",
    url: "https://emora.es/cuentos-infantiles-para-dormir/",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Cuentos infantiles con audio",
    descripcion: "Cuentos cortos gratuitos para leer, cada uno con su audiocuento para escuchar.",
    fuente: "Mumablue",
    url: "https://www.mumablue.com/blog/cuentos-infantiles-para-leer-cortos-gratis/",
    tipo: "externo",
    badge: "Enlace externo",
  },
  {
    titulo: "Muchos Cuentos",
    descripcion: "Catálogo de cuentos por edad y tema, con audiolibros, comprensión lectora y láminas para colorear.",
    fuente: "Muchos Cuentos",
    url: "https://muchoscuentos.com/",
    tipo: "externo",
    badge: "Enlace externo",
  },
];

interface AccesoRapido {
  label: string;
  href: string;
}

const accesosRapidos: AccesoRapido[] = [
  { label: "Explicarle qué pasó", href: "#recursos" },
  { label: "Calmar a la niñez", href: "#cuentos" },
  { label: "Actividades y juego", href: "#imprimibles" },
  { label: "Videos para acompañar", href: "#videos" },
  { label: "Quiero donar", href: "/donaciones?enfoque=ninez" },
];

const pageTitle = "Ayuda para la niñez";
const pageDescription = "Recursos verificados para cuidar y proteger a la niñez durante la emergencia.";

const enlacesLd: { titulo: string; url: string }[] = [
  ...recursos.filter((r) => r.tipo === "externo"),
  ...multimedia.filter((r) => r.tipo === "externo"),
  ...imprimibles.filter((r) => r.tipo === "externo"),
  ...cuentos.filter((c) => c.tipo === "externo"),
].map((r) => ({ titulo: r.titulo, url: r.url }));

const itemListLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: pageTitle,
  description: pageDescription,
  itemListElement: enlacesLd.map((r, i) => ({
    "@type": "ListItem",
    position: i + 1,
    name: r.titulo,
    url: r.url,
  })),
};
---

<Layout
  title={pageTitle}
  description={pageDescription}
  canonical={`${SITE_URL}/proteccion-infantil`}
  showHero={false}
>
  <header class="relative -mt-4 md:-mt-6 mb-6 w-screen ml-[calc(-50vw+50%)] overflow-hidden bg-gradient-to-br from-blue via-blue-dark to-blue text-white">
    <div class="pointer-events-none absolute inset-0 bg-[repeating-linear-gradient(45deg,transparent,transparent_20px,rgba(255,255,255,0.04)_20px,rgba(255,255,255,0.04)_40px)]" aria-hidden="true"></div>
    <div class="relative max-w-[640px] mx-auto text-center px-5 py-10 sm:py-12">
      <span class="inline-flex items-center gap-1.5 bg-white/15 border border-white/25 text-white text-[0.7rem] font-extrabold uppercase tracking-[0.06em] px-3 py-1 rounded-full mb-4">
        <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        Protección infantil
      </span>
      <h1 class="text-2xl sm:text-[1.9rem] font-extrabold tracking-tight leading-tight text-balance mb-2">
        Ayuda para la <span class="text-yellow">niñez</span>
      </h1>
      <p class="text-sm sm:text-[0.9rem] text-white/85 max-w-[480px] mx-auto leading-relaxed text-balance">
        Recursos verificados para cuidar y proteger a la niñez durante la emergencia.
      </p>
    </div>
  </header>

  <section aria-label="Mensaje de bienvenida" class="mb-8 bg-white rounded-card border border-border p-6 sm:p-7 shadow-[0_1px_2px_rgba(16,24,40,0.04)]">
    <p class="text-[1.02rem] sm:text-[1.08rem] font-semibold text-text leading-relaxed text-balance">
      Después de estos días tan difíciles, gran parte de la niñez necesita algo muy sencillo: sentirse segura otra vez.
    </p>
    <p class="mt-3 text-[0.92rem] text-[#4B5563] leading-relaxed text-pretty">
      No hace falta ser experto para ayudar. A veces basta con sentarse a su lado, jugar un rato, escucharla sin apuro, y saber a quién llamar si algo no anda bien.
    </p>
    <p class="mt-3 text-[0.92rem] text-[#4B5563] leading-relaxed text-pretty">
      Aquí reunimos, en un solo lugar, recursos pensados por quienes más saben de esto, para que puedas cuidar a la niñez con cariño… y con la tranquilidad de estar haciendo lo correcto.
    </p>
  </section>

  <nav aria-label="¿Qué necesitas ahora?" class="mb-10">
    <span class="block mb-2 text-[0.68rem] font-bold tracking-[0.08em] uppercase text-muted">¿Qué necesitas ahora?</span>
    <div class="flex flex-wrap gap-2">
      {accesosRapidos.map((a) => (
        <a
          href={a.href}
          class="inline-flex items-center min-h-11 px-[13px] rounded-full border-[1.5px] border-border bg-white text-[0.82rem] font-semibold text-[#374151] no-underline whitespace-nowrap transition-colors duration-150 hover:bg-[#F8F9FB] hover:border-blue hover:text-blue"
        >{a.label}</a>
      ))}
    </div>
  </nav>

  <section id="recursos" aria-labelledby="recursos-titulo" class="mb-10 scroll-mt-24">
    <div class="mb-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center justify-center w-11 h-11 shrink-0 rounded-xl bg-blue shadow-[0_2px_6px_rgba(0,36,125,0.28)]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><path d="m9 12 2 2 4-4"/></svg>
        </span>
        <div class="flex flex-col gap-1">
          <h2 id="recursos-titulo" class="m-0 text-[1.2rem] font-extrabold tracking-tight leading-[1.1] text-blue text-balance">Recursos de protección y apoyo</h2>
          <span class="block w-[42px] h-1 rounded-full bg-yellow"></span>
        </div>
      </div>
      <p class="mt-3 text-[0.86rem] text-muted leading-relaxed text-pretty max-w-[640px]">
        Materiales elaborados por organismos con experiencia en protección infantil. Cada enlace lleva a una fuente confiable con orientación práctica.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
      {recursos.map((r) => (
        r.tipo === "proximamente" ? (
          <article class="relative flex flex-col bg-white rounded-card border border-border p-5 shadow-[0_1px_3px_rgba(16,24,40,0.06)]">
            <div class="flex items-start justify-between gap-3 mb-2.5">
              <span class="inline-flex items-center px-2.5 py-[3px] rounded-md bg-bg text-muted border border-border text-[0.66rem] font-bold uppercase tracking-wide">Próximamente</span>
            </div>
            <h3 class="text-[0.98rem] font-bold text-text leading-snug tracking-tight text-balance mb-2">{r.titulo}</h3>
            <p class="text-[0.86rem] text-[#4B5563] leading-relaxed text-pretty">{r.descripcion}</p>
            <span class="mt-auto pt-3 border-t border-border text-[0.74rem] font-semibold text-muted">{r.fuente}</span>
          </article>
        ) : (
          <a
            href={r.url}
            target={r.tipo === "externo" ? "_blank" : undefined}
            rel={r.tipo === "externo" ? "noopener noreferrer" : undefined}
            class="group relative flex flex-col bg-white rounded-card border border-border p-5 no-underline shadow-[0_1px_3px_rgba(16,24,40,0.06)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-blue hover:shadow-[0_8px_24px_rgba(0,36,125,0.1)]"
          >
            <div class="flex items-start justify-between gap-3 mb-2.5">
              <span class="inline-flex items-center px-2.5 py-[3px] rounded-md bg-[#ECF1FB] text-blue text-[0.66rem] font-bold uppercase tracking-wide">Guía</span>
              <svg class="shrink-0 mt-0.5 text-muted transition-colors duration-200 group-hover:text-blue" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M7 17 17 7M8 7h9v9"/></svg>
            </div>
            <h3 class="text-[0.98rem] font-bold text-text leading-snug tracking-tight text-balance mb-2">{r.titulo}</h3>
            <p class="text-[0.86rem] text-[#4B5563] leading-relaxed text-pretty">{r.descripcion}</p>
            {r.detalle && (
              <p class="mt-2 text-[0.78rem] text-muted italic leading-snug text-pretty">«{r.detalle}»</p>
            )}
            <span class="mt-auto pt-3 border-t border-border text-[0.74rem] text-muted">
              Fuente: <span class="font-semibold text-text">{r.fuente}</span>
            </span>
            {r.tipo === "externo" && <span class="sr-only">(se abre en una nueva pestaña)</span>}
          </a>
        )
      ))}
    </div>
  </section>

  <section id="videos" aria-labelledby="videos-titulo" class="mb-10 scroll-mt-24">
    <div class="mb-4">
      <div class="flex items-center gap-3">
        <span class="inline-flex items-center justify-center w-11 h-11 shrink-0 rounded-xl bg-blue shadow-[0_2px_6px_rgba(0,36,125,0.28)]">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="#FFFFFF" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><rect x="2" y="3" width="20" height="14" rx="2"/><path d="m10 8 5 3-5 3z"/><path d="M8 21h8"/></svg>
        </span>
        <div class="flex flex-col gap-1">
          <h2 id="videos-titulo" class="m-0 text-[1.2rem] font-extrabold tracking-tight leading-[1.1] text-blue text-balance">Videos y recursos multimedia</h2>
          <span class="block w-[42px] h-1 rounded-full bg-yellow"></span>
        </div>
      </div>
      <p class="mt-3 text-[0.86rem] text-muted leading-relaxed text-pretty max-w-[640px]">
        Mismo criterio: plataformas gratuitas, sin publicidad ni suscripción y en español. No alojamos video propio; enlazamos a organizaciones confiables.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-[repeat(auto-fill,minmax(320px,1fr))] gap-4">
      {multimedia.map((r) => (
        <a
          href={r.url}
          target="_blank"
          rel="noopener noreferrer"
          class="group relative flex flex-col bg-white rounded-card border border-border p-5 no-underline shadow-[0_1px_3px_rgba(16,24,40,0.06)] transition-[transform,box-shadow,border-color] duration-200 hover:-translate-y-0.5 hover:border-blue hover:shadow-[0_8px_24px_rgba(0,36,125,0.1)]"
        >
          <div class="flex items-start justify-between gap-3 mb-2.5">
            <span class="inline-flex items-center px-2.5 py-[3px] rounded-md bg-[#ECF1FB] text-blue text-[0.66rem] font-bold uppercase tracking-wide">Multimedia</span>
            <svg class="shrink-0 mt-0.5 text-muted transition-colors duration-200 group-hover:text-blue" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false"><path d="M7 17 17 7M8 7h9v9"/></svg>
          </div>
          <h3 class="text-[0.98rem] font-bold text-text leading-snug tracking-tight text-balance mb-2">{r.titulo}</h3>
